# ---------------------------------------------------------------------------
# CLIA environment configuration
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# ---------------------------------------------------------------------------

# --- WeatherAPI.com -------------------------------------------------------
# Sign up at https://www.weatherapi.com/ to obtain an API key.
WEATHER_API_KEY=your_weatherapi_key_here
WEATHER_API_BASE_URL=http://api.weatherapi.com/v1/current.json

# --- AI analysis & enrichment ---------------------------------------------
# Anthropic (Claude) key for the /analyze AI endpoints.
ANTHROPIC_API_KEY=your_anthropic_key_here
# OpenWeatherMap key for air-quality enrichment (optional; enrichment is
# skipped silently when unset).
OPENWEATHERMAP_API_KEY=your_owm_key_here

# --- PostgreSQL -----------------------------------------------------------
POSTGRES_USER=clia_user
POSTGRES_PASSWORD=clia_password
POSTGRES_DB=clia_db
# Hostname of the database. Inside docker-compose this is the service name `db`
# (set automatically by the compose file). For local runs use `localhost`.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Scheduler ------------------------------------------------------------
# How often to poll all cities, in minutes.
FETCH_INTERVAL_MINUTES=30
# Daily CSV export time, 24h "HH:MM".
CSV_EXPORT_TIME=23:59

# --- Output locations -----------------------------------------------------
EXPORTS_DIR=exports
DATASETS_DIR=datasets
